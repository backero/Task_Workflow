# ─── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://your-app.onrender.com

# ─── Database ─────────────────────────────────────────────────
# Use MongoDB Atlas free cluster: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/backero?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another-random-64-char-string-for-refresh-tokens
JWT_REFRESH_EXPIRES_IN=30d

# ─── OTP ──────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_LENGTH=6

# ─── WhatsApp ────────────────────────────────────────────────
# 'local' = free Baileys (scan QR once, session saved in MongoDB)
# 'console' = dev only, just logs
WHATSAPP_PROVIDER=local
WATI_API_URL=https://live-mt-server.wati.io/xxxxx
WATI_ACCESS_TOKEN=

# ─── File Storage (Cloudinary) ────────────────────────────────
# Leave blank to use local storage (uploads/ folder)
CLOUDINARY_CLOUD_NAME=drst6bcjk
CLOUDINARY_API_KEY=886687956196327
CLOUDINARY_API_SECRET=**********

# ─── SMS Provider (console | msg91 | twilio) ──────────────────
SMS_PROVIDER=console
# MSG91 (used when SMS_PROVIDER=msg91)


MSG91_AUTH_KEY=514590A27r8qXkf69fc40e3P1
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=BCKERO

# Twilio (used when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Seeder (first run only) ──────────────────────────────────
SEED_SUPER_ADMIN_PHONE=+919999999999
SEED_SUPER_ADMIN_NAME=Platform Admin
