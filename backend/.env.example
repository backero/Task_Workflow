# ─── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/backero

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another-random-64-char-string-for-refresh-tokens
