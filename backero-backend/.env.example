# Google Sheets
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# WhatsApp (Baileys)
WA_SESSION_PATH=./wa_session
# Set to false on local to prevent competing with Render over the same MongoDB session (440 loop)
WHATSAPP_ENABLED=true

# WhatsApp Cloud API (official Business API — OTP, task/overdue alerts, etc.)
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_BUSINESS_ACCOUNT_ID=
WHATSAPP_CLOUD_OTP_TEMPLATE=
# Any string you choose — must match the "Verify token" entered in Meta App
# Dashboard > WhatsApp > Configuration when registering the webhook callback URL
# (https://<your-backend>/api/whatsapp/webhook). Enables inbound-message auto-capture
# into CRM leads.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Redis (for Bull queues)
REDIS_URL=redis://localhost:6379

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Rate Limiting (auth endpoints only — no limit on authenticated API routes)
# AUTH_RATE_LIMIT_MAX=30
